(include "./widgets/time/time.yuck")
(include "./widgets/date/date.yuck")

(defwidget bar_layout_center []
	(box
		:class "bar-layout-center"
		(date_widget)
		(time_widget)))

(defwidget bar_layout []
	(centerbox
		:class "bar-layout"
		:orientation "h"
		(box)
		(bar_layout_center)
		(box)))


(defwindow bar
	:monitor 0
	:geometry (geometry
		:x 0
		:y 0
		:width "100%"
		:height "20px"
		:anchor "top center")
	:stacking "fg"
	:exclusive true
	:focusable false
	(bar_layout))
