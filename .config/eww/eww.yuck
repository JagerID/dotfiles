(include "./widgets/time/time.yuck")

(defwidget bar_layout_left []
	(box
		:halign "start"
		:class "bar-layout-center"
		(time_widget)))

(defwidget bar_layout []
	(centerbox
		:class "bar-layout"
		:orientation "h"
		(bar_layout_left)
		(box)
		(box)))

(defwindow bar_m1
	:monitor 1
	:geometry (geometry
		:x 0
		:y 0
		:width "100%"
		:height "16px"
		:anchor "top center")
	:stacking "bg"
	:exclusive true
	:focusable false
	(bar_layout))
