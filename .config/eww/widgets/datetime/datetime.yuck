(defpoll date :interval "1s"
	"date '+%d.%m.%Y'")

(defpoll time :interval "1s"
	"date '+%H:%M:%S'")

(defwidget datetime []
	(box
		:class "glass-container datetime-container"
		:orientation "v"
		:space-evenly false
		:halign "center"
		:valign "center"
		(label :text date)
		(label :text time)))
